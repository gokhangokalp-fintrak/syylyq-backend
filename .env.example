# VITA Backend — Environment Variables
PORT=3001
NODE_ENV=development
JWT_SECRET=vita-jwt-secret-change-in-production
QR_SECRET=vita-qr-hmac-secret-change-in-production

# PostgreSQL bağlantısı
# Local: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=vita123 -e POSTGRES_DB=vita --name vita-db postgres:16
# Render: Platformun verdiği Internal Database URL'yi yapıştır
DATABASE_URL="postgresql://postgres:vita123@localhost:5432/vita?schema=public"

# Log seviyesi: debug | info | warn | error
LOG_LEVEL=info

# iyzico Ödeme Entegrasyonu (Türkiye)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# CORS (production'da frontend URL'i)
CORS_ORIGIN=*
